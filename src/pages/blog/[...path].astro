---
import { getCollection } from "astro:content";
import { default as Layout } from "../../layouts/Article/Article.astro";
import { default as LayoutV2 } from "../../layouts/ArticleV2/ArticleV2.astro";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  return articles.map((page) => {
    return {
      params: { path: page.slug },
      props: { page },
    };
  });
}
const { page } = Astro.props;
const { Content } = await page.render();
const { description, title, date, image, template, titleFontSize } = page.data;
const formattedDate = new Date(date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

{
  template === "ArticleV2" ? (
    <LayoutV2
      title={title}
      description={description}
      date={formattedDate}
      imageUrl={image}
      titleFontSize={titleFontSize}
    >
      <Content />
    </LayoutV2>
  ) : (
    <Layout
      title={title}
      description={description}
      date={formattedDate}
      imageUrl={image}
    >
      <Content />
    </Layout>
  )
}

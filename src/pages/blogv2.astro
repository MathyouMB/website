---
import { getCollection } from "astro:content";
import BlogCategory from "../layouts/BlogCategory/BlogCategory.astro";

const articles = await getCollection("articles");
const nonDraftArticles = articles.filter((article) => !article.data.draft);
const sortedArticles = nonDraftArticles.sort((a, b) => {
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});

const featuredArticles = sortedArticles.filter((article) => {
  return article.data.featured;
});

const featureArticle =
  featuredArticles.length > 0 ? featuredArticles[0] : sortedArticles[0];
---

<BlogCategory
  title="Blog"
  description="Thoughts on software development, careers, and more."
  articles={sortedArticles}
  featuredArticle={featureArticle}
/>

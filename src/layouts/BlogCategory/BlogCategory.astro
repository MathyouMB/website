---
import Main from "../Main/Main.astro";
import "./BlogCategory.scss";

import EmailSubscribe from "../../components/EmailSubscribe/EmailSubscribe.astro";
import BlogPreview from "../../components/BlogPreview/BlogPreview.astro";

interface Post {
  title: string;
  description: string;
  date: string;
  href: string;
  tags: string[];
  imageUrl: string;
  featured?: boolean;
}

interface Props {
  title: string;
  description?: string;
  imageUrl?: string;

  articles?: any[]; // Astro content collection items
  featuredArticle?: any; // Astro content collection item
}

const {
  title,
  description,
  imageUrl,
  articles = [],
  featuredArticle,
} = Astro.props;

const toPost = (article: any): Post => ({
  title: article?.data?.title ?? "Untitled",
  description: article?.data?.description ?? "",
  date: article?.data?.date
    ? new Date(article.data.date).toLocaleDateString("en-US", {
        year: "numeric",
        month: "long",
        day: "numeric",
      })
    : "",
  href: article?.slug ? `/blog/${article.slug}` : "#",
  tags: article?.data?.tags ?? [],
  imageUrl: article?.data?.image ?? "/images/default-blog.png",
  featured: Boolean(article?.data?.featured),
});

const featuredPost: Post | null = featuredArticle
  ? toPost(featuredArticle)
  : null;

const allPosts: Post[] = articles
  .filter((a) => !featuredArticle?.slug || a.slug !== featuredArticle.slug)
  .map(toPost);
---

<Main
  title={title}
  description={description}
  imageUrl={imageUrl}
  styleOverride="background-color: lab(98.2539% -.108749 -.74997);"
>
  <div class="BlogCategory">
    <header class="BlogCategory__header">
      <div class="BlogCategory__headerText">
        <h1 class="BlogCategory__title">{title}</h1>
        {description && <p class="BlogCategory__subtitle">{description}</p>}
      </div>

      {/* Optional: enable when you want it back */}
      {
        /*
      <div style="max-width: 30rem; width: 100%;">
        <EmailSubscribe placeholder="Receive blog updates..." />
      </div>
      */
      }
    </header>

    {/* Mobile-only list (Featured + All) rendered as BlogPreview */}
    <section class="BlogCategory__mobileList">
      {
        featuredPost && (
          <BlogPreview
            title={featuredPost.title}
            description={featuredPost.description}
            date={new Date(featuredPost.date)}
            image={featuredPost.imageUrl}
          />
        )
      }

      {
        allPosts.map((post) => (
          <BlogPreview
            title={post.title}
            description={post.description}
            date={new Date(post.date)}
            image={post.imageUrl}
          />
        ))
      }
    </section>

    {/* Desktop-only featured card */}
    {
      featuredPost && (
        <section class="BlogCategory__featured BlogCategory__desktopOnly">
          <a class="FeaturedCard" href={featuredPost.href}>
            <div class="FeaturedCard__left">
              <div class="FeaturedCard__meta">
                <span class="Pill Pill--blue">Featured</span>
                <span class="FeaturedCard__date">{featuredPost.date}</span>
              </div>

              <h2 class="FeaturedCard__title">{featuredPost.title}</h2>

              <p class="FeaturedCard__desc">{featuredPost.description}</p>

              <div class="FeaturedCard__tags">
                {(featuredPost.tags ?? []).map((t) => (
                  <span class="Pill">{t}</span>
                ))}
              </div>

              <div class="FeaturedCard__cta">
                <span>Read article</span>
                <span class="FeaturedCard__arrow" aria-hidden="true">
                  →
                </span>
              </div>
            </div>

            <div class="FeaturedCard__right" aria-hidden="true">
              <div class="FeaturedCard__imageWrap">
                <img src={featuredPost.imageUrl} alt="" loading="lazy" />
              </div>
            </div>
          </a>
        </section>
      )
    }

    {/* Desktop-only grid */}
    <section class="BlogCategory__all BlogCategory__desktopOnly">
      <div class="BlogCategory__allHeader">
        <h3>All Posts</h3>
        <div class="BlogCategory__rule"></div>
      </div>

      <div class="PostGrid">
        {
          allPosts.map((post) => (
            <a class="PostCard" href={post.href}>
              <div class="PostCard__imageWrap" aria-hidden="true">
                <img src={post.imageUrl} alt="" loading="lazy" />
              </div>

              <div class="PostCard__tags">
                {(post.tags ?? []).map((t) => (
                  <span class="Pill">{t}</span>
                ))}
              </div>

              <div class="PostCard__date">{post.date}</div>

              <h4 class="PostCard__title">{post.title}</h4>
              <p class="PostCard__desc">{post.description}</p>

              <div class="PostCard__cta">
                <span>Read more</span>
                <span class="PostCard__arrow" aria-hidden="true">
                  →
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </section>
  </div>
</Main>
